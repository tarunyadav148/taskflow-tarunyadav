# Database Configuration
DB_URL=jdbc:postgresql://db:5432/taskflow
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# Security
# Generate a base64 string for this in production
# Can you this command to generate string: openssl rand -base64 32

JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long
JWT_EXPIRATION_MS=86400000

# Server
PORT=8080